# Azure AI Foundry — Claude deployments (resource aih-semantic-kernel-swc, swedencentral)
# Copy to .env and fill in. .env is git-ignored.
# Claude on Foundry uses the Anthropic Messages API — the base URL MUST end in
# /anthropic (NOT /models). Confirm the resource name in the Azure portal.
AZURE_FOUNDRY_ENDPOINT=https://aih-semantic-kernel-swc.services.ai.azure.com/anthropic
AZURE_FOUNDRY_API_KEY=your-key-here
AZURE_FOUNDRY_PARSER_DEPLOYMENT=claude-sonnet-5
AZURE_FOUNDRY_FINDER_CRITIC_DEPLOYMENT=claude-opus-4-8
# Drafting Copilot's live chat deployment — same underlying model as
# PARSER_DEPLOYMENT today, kept as its own var for clarity of intent.
AZURE_FOUNDRY_COPILOT_DEPLOYMENT=claude-sonnet-5

# Azure AI Document Intelligence — OPTIONAL PDF ingestion backend.
# When set, PDFs are converted with the prebuilt-layout model, which
# reconstructs reading order (columns, list labels, headings) that the default
# MarkItDown extractor scrambles on BNM's multi-column PDFs. Leave unset to use
# the default extractor. This is a SEPARATE Azure resource from Foundry above.
AZURE_DOCINTEL_ENDPOINT=https://<your-docintel-resource>.cognitiveservices.azure.com/
AZURE_DOCINTEL_API_KEY=your-docintel-key-here
# GA api-version the DI SDK speaks. MarkItDown hardcodes an old preview version
# that GA resources reject with a 404 — this override is required, not optional.
AZURE_DOCINTEL_API_VERSION=2024-11-30
